{
  "functions": {
    "api/search.ts": {
      "maxDuration": 60
    },
    ".output/server/chunks/routes/search*.mjs": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
